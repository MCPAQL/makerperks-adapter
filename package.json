{
  "name": "makerperks-adapter",
  "version": "0.0.0",
  "private": true,
  "description": "Native MCP-AQL adapter over the MakerPerks builder-perks directory",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "spec": "OPENSPEC_TELEMETRY=0 openspec",
    "spec:list": "OPENSPEC_TELEMETRY=0 openspec list",
    "spec:validate": "OPENSPEC_TELEMETRY=0 openspec validate"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fission-ai/openspec": "1.4.1",
    "@types/node": "26.0.1",
    "eslint": "10.5.0",
    "prettier": "3.8.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "fuse.js": "7.4.2"
  }
}
