{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "makerperks-adapter",
  "main": "dist/worker.js",
  "compatibility_date": "2026-06-03",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": { "enabled": true },
  "routes": [{ "pattern": "makerperks.mcpaql.com", "custom_domain": true }],
  "kv_namespaces": [{ "binding": "OAUTH_KV", "id": "609312bdeb5e4379afe0b61bd123a1a8" }],
}
