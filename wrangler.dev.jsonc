{
  // Stage 1 STATEFUL deployment — separate from the live makerperks.mcpaql.com.
  // Deploy with `npm run deploy:dev`. The live Worker (wrangler.jsonc + src/worker.ts)
  // is never touched by this config. See openspec/changes/add-stateful-hosting (#20).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "makerperks-adapter-dev",
  "main": "dist/worker-stateful.js",
  "compatibility_date": "2026-06-03",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": { "enabled": true },
  "routes": [{ "pattern": "makerperks-dev.mcpaql.com", "custom_domain": true }],
  // A SEPARATE OAuth grant store (namespace title `OAUTH_KV_DEV`) — real-auth grants must
  // not mingle with the live worker's `OAUTH_KV` (609312bd…). Bound as `OAUTH_KV` (what the
  // code reads).
  "kv_namespaces": [
    { "binding": "OAUTH_KV", "id": "ff6361cd98624fb3845c8f859e64bdde" },
    // SHARED overlay mirror (#87) — reconcile_flows writes the accepted overlay here; the read-only
    // worker reads the SAME namespace to serve blessed flows. One namespace, bound on both workers.
    { "binding": "OVERLAY_KV", "id": "486d676413c145a7bb5c81553960d611" },
  ],
  // Durable Objects: one per MCP session (McpAgent, `MCP_OBJECT`); one per USER for the
  // profile + encrypted vault + audit log (`PROFILE_OBJECT`, #51), addressed by userId.
  "durable_objects": {
    "bindings": [
      { "name": "MCP_OBJECT", "class_name": "MakerPerksMcpAgent" },
      { "name": "PROFILE_OBJECT", "class_name": "MakerProfileDO" },
      // SHARED proposed-flow registry — one named instance for the whole deployment (#47 piece D).
      { "name": "REGISTRY_OBJECT", "class_name": "FlowRegistryDO" },
    ],
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["MakerPerksMcpAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["MakerProfileDO"] },
    { "tag": "v3", "new_sqlite_classes": ["FlowRegistryDO"] },
  ],
  // Operator policy (#90) — who may ACCEPT proposals into the served set (users only propose).
  // Non-secret + configurable. Both are set here (OR'd): operator = admin on OPERATOR_REPO (read
  // with the user's own token) OR login in OPERATOR_LOGINS. Edit/remove either to retune; setting
  // neither would fail safe (no operators). OPERATOR_REPO active also bumps the OAuth scope to
  // public_repo for every user (it must read repo permissions).
  "vars": {
    "OPERATOR_REPO": "MCPAQL/makerperks-adapter",
    "OPERATOR_LOGINS": "mickdarling",
  },
  // Per-IP rate-limit backstop (mirrors the live worker). 100 requests / 10s per IP.
  "ratelimits": [
    {
      "name": "MCP_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 100, "period": 10 },
    },
  ],
  // Real per-user OAuth (§3) delegates /authorize to GitHub. Three secrets are required —
  // set them on this Worker (NOT committed):
  //   wrangler secret put GITHUB_CLIENT_ID     -c wrangler.dev.jsonc
  //   wrangler secret put GITHUB_CLIENT_SECRET -c wrangler.dev.jsonc
  //   wrangler secret put VAULT_KEY            -c wrangler.dev.jsonc   # base64 of 32 random bytes
  // Register the GitHub OAuth App with callback https://makerperks-dev.mcpaql.com/callback.
  // Generate a vault key with:  node -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64'))"
}
