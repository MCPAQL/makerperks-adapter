{
  // Stage 1 STATEFUL deployment — separate from the live makerperks.mcpaql.com.
  // Deploy with `npm run deploy:dev`. The live Worker (wrangler.jsonc + src/worker.ts)
  // is never touched by this config. See openspec/changes/add-stateful-hosting (#20).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "makerperks-adapter-dev",
  "main": "dist/worker-stateful.js",
  "compatibility_date": "2026-06-03",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": { "enabled": true },
  "routes": [{ "pattern": "makerperks-dev.mcpaql.com", "custom_domain": true }],
  // A SEPARATE OAuth grant store (namespace title `OAUTH_KV_DEV`) — real-auth grants must
  // not mingle with the live worker's `OAUTH_KV` (609312bd…). Bound as `OAUTH_KV` (what the
  // code reads).
  "kv_namespaces": [
    { "binding": "OAUTH_KV", "id": "ff6361cd98624fb3845c8f859e64bdde" },
  ],
  // One Durable Object per MCP session (McpAgent). Default binding name `MCP_OBJECT`.
  "durable_objects": {
    "bindings": [{ "name": "MCP_OBJECT", "class_name": "MakerPerksMcpAgent" }],
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["MakerPerksMcpAgent"] }],
  // Per-IP rate-limit backstop (mirrors the live worker). 100 requests / 10s per IP.
  "ratelimits": [
    {
      "name": "MCP_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 100, "period": 10 },
    },
  ],
  // Real per-user OAuth (§3) delegates /authorize to GitHub. Two secrets are required —
  // set them on this Worker (NOT committed):
  //   wrangler secret put GITHUB_CLIENT_ID     -c wrangler.dev.jsonc
  //   wrangler secret put GITHUB_CLIENT_SECRET -c wrangler.dev.jsonc
  // Register the GitHub OAuth App with callback https://makerperks-dev.mcpaql.com/callback.
}
